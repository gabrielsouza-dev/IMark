@inject TimeCheckService TimeCheckService
@inject NavigationManager NavigationManager

@attribute [Authorize]
@page "/Geral"


<div class="records-wrap">

    @if (!_timeEntries.Any())
    {
        <div class="empty-msg">
            Nenhum ponto registrado
        </div>
    }
    else
    {

        <!-- DESKTOP -->
        <div class="desktop-table">

            <table class="table table-sm align-middle">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Data</th>
                        <th>Horários</th>
                        <th>Total</th>
                        <th>Consistência</th>
                        <th>Status</th>
                    </tr>
                </thead>


                <tbody>

                    @foreach (var (timeEntry, index) in _timeEntries.Select((c, i) => (c, i + 1)))
                    {
                        <tr>

                            <td>@index</td>

                            <td>
                                @timeEntry.Date.ToString("dd/MM/yyyy")
                            </td>


                            <td>

                                <div class="times">

                                    @foreach (var check in timeEntry.Checks.OrderBy(c => c.TimestampLocal))
                                    {
                                        <span>
                                            @check.TimestampLocal.ToString("HH:mm")
                                        </span>
                                    }

                                </div>

                            </td>


                            <td>
                                @timeEntry.HoursWorked.ToString(@"hh\:mm\:ss")
                            </td>


                            <td>
                                @(timeEntry.IsConsistent ? "Consistente" : "Inconsistente")
                            </td>


                            <td>
                                @(timeEntry.Status == TimeEntryStatus.Accepted
                                    ? "Aceito"
                                    : "Pendente")
                            </td>


                        </tr>
                    }

                </tbody>

            </table>

        </div>



        <!-- MOBILE -->

        <div class="mobile-list">


            @foreach (var (timeEntry, index) in _timeEntries.Select((c, i) => (c, i + 1)))
            {

                <div class="record-card">


                    <div class="card-header">

                        <div>

                            <span class="number">
                                #@index
                            </span>

                            <span class="date">
                                @timeEntry.Date.ToString("dd/MM/yyyy")
                            </span>

                        </div>


                        <span class="status
                            @(timeEntry.Status == TimeEntryStatus.Accepted
                                  ? "accepted"
                                  : "pending")">

                            @(timeEntry.Status == TimeEntryStatus.Accepted
                                ? "Aceito"
                                : "Pendente")

                        </span>


                    </div>



                    <div class="card-section">


                        <div class="section-label">
                            Horários
                        </div>


                        <div class="times">


                            @foreach (var check in timeEntry.Checks.OrderBy(c => c.TimestampLocal))
                            {

                                <span>
                                    @check.TimestampLocal.ToString("HH:mm")
                                </span>

                            }


                        </div>


                    </div>




                    <div class="card-info">


                        <div>
                            <span>Total</span>

                            <strong>
                                @timeEntry.HoursWorked.ToString(@"hh\:mm\:ss")
                            </strong>
                        </div>



                        <div>

                            <span>Consistência</span>


                            <strong class="
                                @(timeEntry.IsConsistent
                                        ? "consistent"
                                        : "inconsistent")">

                                @(timeEntry.IsConsistent
                                    ? "Consistente"
                                    : "Inconsistente")

                            </strong>

                        </div>


                    </div>


                </div>

            }


        </div>

    }

</div>



@code {

    private List<TimeEntryDTO> _timeEntries = new();
    private string _errorMessage = string.Empty;


    protected override async Task OnInitializedAsync()
    {
        try
        {
            _timeEntries = await TimeCheckService.GetAll();
        }
        catch (HttpRequestException ex)
        {
            NavigationManager.NavigateTo($"/error?code={(int)ex.StatusCode!}", forceLoad: false);
        }
    }

}